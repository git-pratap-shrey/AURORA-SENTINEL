# ============================================================
# AURORA SENTINEL — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)
# ============================================================

# ----------------------------------------------------------
# VLM (Vision Language Model) Provider
# ----------------------------------------------------------
# Options: gemini | ollama
# - gemini : Uses Google Gemini API (requires GEMINI_API_KEY below)
# - ollama  : Uses local Ollama instance (free, runs on your machine)
VLM_PROVIDER=ollama

# ----------------------------------------------------------
# Google Gemini API Key (only needed if VLM_PROVIDER=gemini)
# ----------------------------------------------------------
# Get your free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ----------------------------------------------------------
# Ollama Configuration (only needed if VLM_PROVIDER=ollama)
# ----------------------------------------------------------
# Default model used for scene analysis. Must be a vision-capable model.
# Recommended: llava, llava:13b, moondream, bakllava
# Run: ollama pull llava   (to download the model first)
OLLAMA_MODEL=llava

# Ollama server URL (default is fine for local installs)
# OLLAMA_HOST=http://localhost:11434

# ----------------------------------------------------------
# Database (optional — SQLite used by default for local dev)
# ----------------------------------------------------------
# Uncomment and set these only if you are using PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/aurora_db

# ----------------------------------------------------------
# Redis (optional — only needed for production caching)
# ----------------------------------------------------------
# REDIS_URL=redis://localhost:6379
